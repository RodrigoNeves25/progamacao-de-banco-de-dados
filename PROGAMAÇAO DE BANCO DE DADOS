USE escola;
CREATE DATABASE escola ;

CREATE TABLE alunos (
id_aluno INT PRIMARY kEY,
nome VARCHAR (100),
data_nascimento DATE ,
email VARCHAR (100)
);

CREATE TABLE cursos (
id_curso INT PRIMARY KEY,
nome_curso VARCHAR (100),
carga_horaria INT 
);

CREATE TABLE matriculas (
id_matricula INT PRIMARY KEY ,
id_aluno INT ,
id_curso INT,
data_matricula DATE,
